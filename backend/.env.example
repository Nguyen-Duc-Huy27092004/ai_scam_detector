# .env.example — copy this to .env and fill in real values
# NEVER commit .env to version control.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: ollama | openai | gemini
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_TIMEOUT=15
LLM_MAX_TOKENS=512

# ── External API Keys ─────────────────────────────────────────────────────────
# Optional — enables PhishTank blocklist check.
PHISHTANK_API_KEY=

# Optional — only required if using a commercial LLM router.
ONEROUTER_API_KEY=
ONEROUTER_URL=https://api.onerouter.ai/v1/chat/completions

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
DEBUG=false
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ANALYZE=10 per minute
RATE_LIMIT_DEFAULT=100 per hour

# ── Cleanup ───────────────────────────────────────────────────────────────────
SCREENSHOT_MAX_AGE_HOURS=24
